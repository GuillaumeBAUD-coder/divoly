generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  image     String?
  bio       String?
  createdAt DateTime @default(now())
  answers   Answer[]
  requests  AnswerRequest[]
  votes     Vote[]
  savedAnswers SavedAnswer[]
  collections AnswerCollection[]
  followedRequests FollowedRequest[]
  searchHistory SearchHistory[]
  sessions  Session[]
  accounts  Account[]
}

model Answer {
  id          String   @id @default(cuid())
  prompt      String   @db.Text
  answer      String   @db.Text
  model       String
  modelColor  String   @default("#818cf8")
  category    String
  tags        String[]
  upvotes     Int      @default(0)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes       Vote[]
  savedBy     SavedAnswer[]
  collectionItems CollectionItem[]

  @@index([category])
  @@index([model])
  @@index([createdAt(sort: Desc)])
}

model SavedAnswer {
  id        String   @id @default(cuid())
  userId    String
  answerId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer    Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@unique([userId, answerId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([answerId])
}

model AnswerCollection {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CollectionItem[]

  @@index([userId, updatedAt(sort: Desc)])
}

model CollectionItem {
  id           String           @id @default(cuid())
  collectionId String
  answerId     String
  createdAt    DateTime         @default(now())
  collection   AnswerCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  answer       Answer           @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@unique([collectionId, answerId])
  @@index([collectionId, createdAt(sort: Desc)])
  @@index([answerId])
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  answerId  String
  value     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer    Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@unique([userId, answerId])
}

model AnswerRequest {
  id              String   @id @default(cuid())
  query           String   @db.Text
  normalizedQuery String   @unique
  category        String?
  status          String   @default("open")
  requestCount    Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  followers       FollowedRequest[]

  @@index([status, requestCount(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model FollowedRequest {
  id        String        @id @default(cuid())
  userId    String
  requestId String
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  request   AnswerRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([userId, requestId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([requestId])
}

model SearchHistory {
  id              String   @id @default(cuid())
  userId          String
  query           String   @db.Text
  normalizedQuery String
  category        String?
  model           String?
  resultCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedQuery])
  @@index([userId, updatedAt(sort: Desc)])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
